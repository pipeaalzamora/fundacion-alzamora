# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_MAPS_API_KEY: clave de Google Maps Platform.
# Habilita el mapa real de Google (sección de mapa) y el autocompletado de
# direcciones de Google Places (formulario de alertas de calle).
# Cómo obtenerla:
#   1. Crea un proyecto en https://console.cloud.google.com
#   2. Habilita las APIs: "Maps JavaScript API" y "Places API"
#   3. Crea una API key en Credenciales y restríngela por referрер HTTP
#      (tu dominio) y por API (solo Maps JavaScript + Places API).
# Si se deja vacía, el mapa usa la versión estilizada y el campo de dirección
# funciona como texto normal (la app sigue operando sin problemas).
VITE_GOOGLE_MAPS_API_KEY=""

# VITE_API_URL: URL base del backend Express que expone la API real
# (donaciones, transparencia, voluntarios y alertas de calle).
# Debe llevar el prefijo VITE_ para que Vite lo exponga al frontend.
# Si no se define, el cliente usa http://localhost:4000 por defecto.
# Ejemplo en producción: https://api.fundacionalzamora.org
VITE_API_URL="http://localhost:4000"

# ---------------------------------------------------------------------------
# Firebase Authentication — Login con Google del Panel de Administración
# ---------------------------------------------------------------------------
# El panel admin (pestaña "admin", enlace discreto del footer) usa Firebase
# Authentication con inicio de sesión de Google. Solo la cuenta autorizada
# (VITE_ADMIN_EMAIL) puede ingresar; tras el login se obtiene el ID token de
# Firebase y se envía como "Authorization: Bearer <token>" a las rutas admin
# del backend, que verifica el token y valida el email.
#
# Cómo obtener estos valores:
#   1. Crea un proyecto en https://console.firebase.google.com
#   2. Authentication > Sign-in method > habilita "Google".
#   3. Project settings > General > "Tus apps" > agrega una app Web y copia
#      los valores de la config (apiKey, authDomain, projectId, appId).
#   4. Authentication > Settings > Authorized domains: agrega tu dominio.
#
# Si estas variables VITE_FIREBASE_* NO están definidas, el panel admin usa el
# fallback de desarrollo (input de token manual guardado en sessionStorage).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_APP_ID=""

# VITE_ADMIN_EMAIL: única cuenta de Google autorizada a entrar al panel admin.
# Se compara en minúsculas. Por defecto: pipeaalzamora@gmail.com
VITE_ADMIN_EMAIL="pipeaalzamora@gmail.com"
